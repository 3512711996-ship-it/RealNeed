# Copy to .env.production for a self-hosted deployment. Replace every value.
NODE_ENV=production
PUBLIC_APP_URL=https://realneed.example.com

# PostgreSQL service credentials for docker compose.
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
# Set this to the real production connection string. It is intentionally blank
# so an example file can never be mistaken for a deployable credential.
DATABASE_URL=

# Redis is mandatory for shared production rate limiting.
REDIS_PASSWORD=replace-with-a-long-random-redis-password
REDIS_URL=redis://:replace-with-a-long-random-redis-password@redis:6379
RATE_LIMIT_PROVIDER=redis

# Generate with: npm run byok:setup-encryption
API_CREDENTIAL_ENCRYPTION_KEY=replace-with-a-32-byte-base64-key
API_CREDENTIAL_ENCRYPTION_KEY_VERSION=1

# The official deployment is always free BYOK.
REPORT_GENERATION_API_MODE=USER_PROVIDED_REQUIRED
ALLOW_INSTANCE_API_FOR_REPORTS=false
JOB_EXECUTION_MODE=worker
WORKER_ID=realneed-worker-1
JOB_POLL_INTERVAL_MS=1500
JOB_LOCK_TIMEOUT_SECONDS=120
JUDGMENT_JOB_TIMEOUT_SECONDS=480
DEEP_DIVE_JOB_TIMEOUT_SECONDS=300
DATA_CLEANUP_JOB_TIMEOUT_SECONDS=300

REPORT_RETENTION_DAYS=30
REPORT_LINK_RETENTION_DAYS=30
SOURCE_CONTENT_RETENTION_DAYS=7
ANALYTICS_RETENTION_DAYS=180
API_USAGE_RETENTION_DAYS=365
JOB_EVENT_RETENTION_DAYS=30

# Optional, independent support/contact configuration. Never use it for access.
INSTANCE_DEVELOPER_NAME=
INSTANCE_CONTACT_WECHAT=
INSTANCE_CONTACT_QR_URL=
INSTANCE_DONATION_QR_URL=
INSTANCE_GITHUB_URL=
INSTANCE_ISSUES_URL=
INSTANCE_SUPPORT_MESSAGE=
