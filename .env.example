# Copy to .env.local for development. Never commit a real value.
DATABASE_URL=
PUBLIC_APP_URL=http://localhost:3000

# RealNeed stores user-provided credentials with AES-256-GCM. Generate this locally:
# npm run byok:setup-encryption
API_CREDENTIAL_ENCRYPTION_KEY=
API_CREDENTIAL_ENCRYPTION_KEY_VERSION=1
API_CREDENTIAL_RETENTION_HOURS=24

# Official default: every Deep Dive uses a user-provided generation credential.
REPORT_GENERATION_API_MODE=USER_PROVIDED_REQUIRED
ALLOW_INSTANCE_API_FOR_REPORTS=false

# Local development may run jobs inline. Production must use a separate Worker.
JOB_EXECUTION_MODE=inline
WORKER_ID=realneed-local-worker
JOB_POLL_INTERVAL_MS=1500
JOB_LOCK_TIMEOUT_SECONDS=120
JOB_MAX_RUNTIME_SECONDS=180
JUDGMENT_JOB_TIMEOUT_SECONDS=480
DEEP_DIVE_JOB_TIMEOUT_SECONDS=300
DATA_CLEANUP_JOB_TIMEOUT_SECONDS=300

# Production should use Redis for shared rate limiting.
RATE_LIMIT_PROVIDER=memory
REDIS_URL=

REPORT_RETENTION_DAYS=30
REPORT_LINK_RETENTION_DAYS=30
SOURCE_CONTENT_RETENTION_DAYS=7
ANALYTICS_RETENTION_DAYS=180
API_USAGE_RETENTION_DAYS=365
JOB_EVENT_RETENTION_DAYS=30

# Optional independent support/contact configuration. It never grants access.
INSTANCE_DEVELOPER_NAME=
INSTANCE_CONTACT_WECHAT=
INSTANCE_CONTACT_QR_URL=
INSTANCE_DONATION_QR_URL=
INSTANCE_GITHUB_URL=
INSTANCE_ISSUES_URL=
INSTANCE_SUPPORT_MESSAGE=
